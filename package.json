{
  "name": "smart-retail-os",
  "private": true,
  "version": "1.0.0",
  "description": "Smart Retail OS Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/domain/*",
    "packages/application/*",
    "packages/infrastructure/*"
  ],
  "scripts": {
    "dev": "npm run --workspaces dev --if-present",
    "dev:backend": "npm run dev --workspace @apps/backend",
    "dev:desktop": "npm run dev --workspace @apps/desktop",
    "dev:android": "npm run dev --workspace @apps/android",
    "build": "npm run build:backend && npm run build:desktop && npm run build:android",
    "build:backend": "npm run build --workspace @apps/backend",
    "build:desktop": "npm run build --workspace @apps/desktop",
    "build:android": "npm run build --workspace @apps/android",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{apps,packages}/**/*.{ts,tsx}\"",
    "typecheck": "npm run --workspaces typecheck --if-present",
    "typecheck:backend": "npm run typecheck --workspace @apps/backend",
    "typecheck:desktop": "npm run typecheck --workspace @apps/desktop",
    "typecheck:android": "npm run typecheck --workspace @apps/android",
    "mongo:migrate": "npx dotenv -e .env -- npx ts-node --esm packages/infrastructure/mongodb/src/cli/run-migrations.ts up",
    "mongo:seed": "npx dotenv -e .env -- npx ts-node --esm packages/infrastructure/mongodb/src/cli/run-seeds.ts",
    "db:refresh": "npm run mongo:migrate && npm run mongo:seed",
    "refresh": "npm run db:refresh",
    "migrate": "npm run mongo:migrate",
    "seed": "npm run mongo:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "mongodb-client-encryption": "^6.5.0",
    "zod": "^4.4.3"
  }
}
