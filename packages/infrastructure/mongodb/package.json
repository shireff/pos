{
  "name": "@packages/infrastructure-mongodb",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node --esm src/cli/run-migrations.ts up",
    "seed": "ts-node --esm src/cli/run-seeds.ts",
    "refresh": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "@packages/shared-kernel": "*",
    "mongodb": "6.5.0",
    "mongoose": "8.3.0",
    "mongodb-client-encryption": "^6.5.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.12"
  }
}
